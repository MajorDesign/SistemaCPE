# =========================================
# Banco de Dados MySQL
# =========================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=cpe_plus
MYSQL_USER=root
MYSQL_PASSWORD=

# =========================================
# Segurança da Aplicação
# =========================================
# Chave secreta para assinar tokens de sessão (mude em produção!)
APP_SECRET=DEV_CHANGE_ME_123

# Chave para proteger endpoints /api/dev/* (remover em produção!)
DEV_API_KEY=DEV_CPE_2026_SUPER_SECRET

# =========================================
# CORS - Origens Permitidas
# =========================================
# Liste TODOS os domínios que podem acessar a API
# Separe múltiplas URLs por vírgula (sem espaços)
#
# Exemplos:
#   - Frontend em http://localhost → adicione http://localhost
#   - Frontend em http://127.0.0.1 → adicione http://127.0.0.1
#   - Frontend em https://seusite.com → adicione https://seusite.com
#
# ⚠️ IMPORTANTE: Use SEMPRE o mesmo domínio para Frontend + Backend
#    Não misture http://localhost com http://127.0.0.1
#
CORS_ORIGINS=http://localhost,http://localhost:5500,http://localhost:8000,http://localhost:8080

# =========================================
# Configuração de Sessão
# =========================================
# Nome do cookie de sessão
SESSION_COOKIE_NAME=cpe_session

# Tempo de expiração da sessão em segundos (7 dias)
SESSION_MAX_AGE=604800

# =========================================
# Ambiente
# =========================================
# Valores: development, staging, production
ENVIRONMENT=development